{
  "name": "cvoed-tools",
  "version": "1.0.0",
  "description": "**Versión:** 1.1.0 **Para:** IMSS - Copa Mundial FIFA 2026 **Licencia:** Apache License 2.0 **Fecha:** Marzo 2026",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "bash build.sh production",
    "build:dev": "bash build.sh development",
    "build:clean": "bash build.sh production true",
    "verify": "bash verify-build.sh",
    "prebuild": "npm run verify",
    "postbuild": "npm run verify",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,html,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,html,css,md,json}\"",
    "format:js": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:watch": "prettier --write \"**/*.{js,jsx,ts,tsx,html,css,md,json}\" --watch",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:unit": "NODE_ENV=test jest tests/unit",
    "test:integration": "NODE_ENV=test jest tests/integration",
    "test:e2e": "NODE_ENV=test jest tests/e2e",
    "env:dev": "cp .env.development .env",
    "env:prod": "cp .env.production .env",
    "env:test": "cp .env.test .env"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "babel-jest": "^30.2.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "fake-indexeddb": "^6.2.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-html-reporters": "^3.1.7",
    "jsdom": "^25.0.0",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
