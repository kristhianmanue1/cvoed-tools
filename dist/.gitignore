# ============================================
# CVOED-TOOLS - Git Ignore (Solo HTML Portátiles)
# ============================================

# EXCLUIR TODO
*

# ============================================
# PERMITIR: HTML Portátiles (dist/)
# ============================================
!dist/
!dist/*.html

# ============================================
# PERMITIR: Documentación esencial
# ============================================
!README.md
!LICENSE
!create-release-zip.sh

# ============================================
# PERMITIR: .gitignore
# ============================================
!.gitignore

# ============================================
# EXCLUIR EXPLÍCITAMENTE
# ============================================
src/
tests/
docs/
config/
scripts/
public/
coverage/
.adrc/
.github/
tools/
node_modules/
package*.json

# ZIP generados (se crean con script)
*.zip
