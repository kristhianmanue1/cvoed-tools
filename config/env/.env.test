# CVOED-Tools - Testing Environment

# Application
NODE_ENV=test
APP_NAME=CVOED-Tools
APP_VERSION=2.0.0-test
API_URL=http://localhost:3000

# Features
FEATURE_PIN_HASHING=true
FEATURE_WEB_WORKERS=true
FEATURE_DARK_MODE=false
FEATURE_DEBUG_MODE=true

# Database
DB_NAME=ECEDES_TEST_DB
DB_VERSION=1
DB_TIMEOUT=2000

# Export
EXPORT_MAX_ROWS=1000
EXPORT_TIMEOUT=10000

# Session
SESSION_TIMEOUT=60000
SESSION_WARNING=10000

# Logging
LOG_LEVEL=error
LOG_TO_CONSOLE=false

# Testing
TEST_TIMEOUT=10000
HEADLESS=true
